import express, { type Request, Response, NextFunction } from "express";
import { registerRoutes } from "./routes";
import { serveStatic } from "./static";
import { createServer } from "http";
import { runMigrations } from "./migrate";
import { startScheduler } from "./engine/scheduler";
import { startHeartbeats } from "./engine/heartbeat-scheduler";
import { startQueueWorker } from "./engine/queue-worker";
import { seedBuiltInTemplates } from "./lib/agent-templates-seed";

const app = express();
const httpServer = createServer(app);

